rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isMatchParticipant(matchId) {
      return isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.users;
    }

    match /users/{userId} {
      allow read, update, create: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /profiles/{profileId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && request.auth.uid == profileId;
      allow delete: if false;
    }

    match /purchase_events/{eventId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /matches/{matchId} {
      allow read: if isMatchParticipant(matchId);
      allow create, update: if isSignedIn() && request.auth.uid in request.resource.data.users;
      allow delete: if false;
    }

    match /chats/{chatId} {
      allow read: if isMatchParticipant(chatId);
      allow create, update, delete: if false;
    }

    match /chats/{chatId}/messages/{messageId} {
      allow read: if isMatchParticipant(chatId);
      allow create: if isMatchParticipant(chatId) && request.resource.data.senderId == request.auth.uid;
      allow update, delete: if false;
    }

    match /blocks/{blockId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.byUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /reports/{reportId} {
      allow create: if isSignedIn() && request.resource.data.byUserId == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
